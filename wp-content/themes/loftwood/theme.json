{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        {
          "slug": "bronze",
          "color": "#b9a380",
          "name": "Bronze"
        },
        {
          "slug": "slate",
          "color": "#535D6A",
          "name": "Slate"
        },
        {
          "slug": "eco-green",
          "color": "#2D5A3D",
          "name": "Eco Green"
        },
        {
          "slug": "eco-green-light",
          "color": "#3A7A52",
          "name": "Eco Green Light"
        },
        {
          "slug": "cream",
          "color": "#FBFAF8",
          "name": "Cream"
        },
        {
          "slug": "warm-white",
          "color": "#F7EEE8",
          "name": "Warm White"
        },
        {
          "slug": "foreground",
          "color": "#1a1a1a",
          "name": "Foreground"
        },
        {
          "slug": "foreground-dark",
          "color": "#2C3E44",
          "name": "Foreground Dark"
        },
        {
          "slug": "background",
          "color": "#ffffff",
          "name": "Background"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
          "name": "Inter",
          "slug": "inter",
          "fontFace": [
            {
              "fontFamily": "Inter",
              "fontWeight": "100 900",
              "fontDisplay": "swap",
              "fontStyle": "normal",
              "src": ["https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap"]
            }
          ]
        },
        {
          "fontFamily": "'Montserrat', sans-serif",
          "name": "Montserrat",
          "slug": "montserrat",
          "fontFace": [
            {
              "fontFamily": "Montserrat",
              "fontWeight": "100 900",
              "fontDisplay": "swap",
              "fontStyle": "normal",
              "src": ["https://fonts.googleapis.com/css2?family=Montserrat:wght@100..900&display=swap"]
            }
          ]
        },
        {
          "fontFamily": "'Cormorant Garamond', Georgia, serif",
          "name": "Cormorant",
          "slug": "cormorant",
          "fontFace": [
            {
              "fontFamily": "Cormorant Garamond",
              "fontWeight": "400 700",
              "fontDisplay": "swap",
              "fontStyle": "normal",
              "src": ["https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&display=swap"]
            }
          ]
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.875rem", "name": "Small" },
        { "slug": "medium", "size": "1rem", "name": "Medium" },
        { "slug": "large", "size": "1.25rem", "name": "Large" },
        { "slug": "x-large", "size": "1.5rem", "name": "Extra Large" },
        { "slug": "xx-large", "size": "clamp(2rem, 5vw, 3.125rem)", "name": "Huge" }
      ]
    },
    "layout": {
      "contentSize": "800px",
      "wideSize": "1200px"
    },
    "spacing": {
      "units": ["px", "em", "rem", "vh", "vw", "%"]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--foreground)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--inter)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.6"
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--eco-green)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--bronze)"
          }
        }
      },
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--montserrat)",
          "fontWeight": "500"
        }
      },
      "h1": {
        "typography": { "fontSize": "clamp(2rem, 5vw, 3.125rem)" }
      },
      "h2": {
        "typography": { "fontSize": "clamp(1.5rem, 4vw, 2.5rem)" }
      },
      "h3": {
        "typography": { "fontSize": "clamp(1.25rem, 3vw, 2rem)" }
      }
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ]
}
